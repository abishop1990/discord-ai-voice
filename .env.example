# Required
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_OWNER_ID=your_discord_user_id

# LLM API key — set the one that matches your LLM_MODEL
# Claude (default):  ANTHROPIC_API_KEY=<your key>
# OpenAI:            OPENAI_API_KEY=sk-...
# Gemini:            GEMINI_API_KEY=...
# OpenRouter:        OPENROUTER_API_KEY=sk-or-...
# Ollama (local):    no key needed; set OLLAMA_API_BASE=http://localhost:11434
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional — LiteLLM model string (no code change needed to switch providers)
# Examples: gpt-4o  |  gemini/gemini-2.0-flash  |  ollama/llama3
#           openrouter/anthropic/claude-haiku-4-5-20251001
LLM_MODEL=claude-haiku-4-5-20251001

# Optional — Kokoro neural TTS (runs locally, no API key)
# American English: af_heart (default), af_bella, af_sarah, af_nicole
#                   am_michael, am_adam, am_echo
# British English:  bf_emma, bf_isabella, bm_george, bm_lewis
TTS_VOICE=af_heart
TTS_SPEED=1.0

# Optional — paths to Kokoro model files (see README for download instructions)
# KOKORO_MODEL=~/.cache/kokoro-onnx/kokoro-v1.0.int8.onnx
# KOKORO_VOICES=~/.cache/kokoro-onnx/voices-v1.0.bin

# Optional — path to libespeak-ng (required if espeak-ng is not on system PATH)
# macOS (homebrew): ESPEAK_LIB=/opt/homebrew/lib/libespeak-ng.dylib
# Linux:            ESPEAK_LIB=/usr/lib/x86_64-linux-gnu/libespeak-ng.so.1
# ESPEAK_LIB=/opt/homebrew/lib/libespeak-ng.dylib

# Optional — addressing / wake-word behavior
# BOT_NAME: the bot only responds to voice when this name appears in the transcript,
# OR within CONVERSATION_WINDOW seconds of the last time it was named.
# Set to the bot's name in your Discord server (case-insensitive match).
BOT_NAME=bot
CONVERSATION_WINDOW=30

# Optional — other defaults
WHISPER_URL=http://127.0.0.1:8765/inference
SILENCE_SEC=0.7
MIN_DURATION_SEC=0.4
